{
  "name": "global-flight-analytics",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "verify:web-dependencies": "node scripts/verify-frontend-dependency-security.mjs",
