# Shared PostgreSQL configuration
DATABASE_URL=postgresql://username:password@host/database?sslmode=require
DATABASE_CONNECT_TIMEOUT=5s

# API server
API_PORT=8080

# API protection
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
API_BODY_LIMIT_BYTES=1048576
API_READ_TIMEOUT=10s
API_WRITE_TIMEOUT=15s
API_IDLE_TIMEOUT=60s
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW=1m

# Internal mutation authorization
# Generate a raw key:
# KEY="$(openssl rand -hex 32)"
# Compute the backend-only digest:
# printf '%s' "$KEY" | shasum -a 256
# Store only the 64-character digest in backend secret configuration.
API_MUTATION_KEY_SHA256=

# Open-Meteo integration
OPEN_METEO_TIMEOUT=10s

# Regional traffic ingestion
TRAFFIC_INGESTION_LATITUDE=40.4093
TRAFFIC_INGESTION_LONGITUDE=49.8671
TRAFFIC_INGESTION_RADIUS=100

# Airplanes Live integration
AIRPLANES_LIVE_TIMEOUT=10s

# Trajectory segmentation policy
# Zero disables the corresponding threshold.
TRAJECTORY_MAX_TIME_GAP=90s
TRAJECTORY_MAX_GROUND_SPEED_MPS=420

# OurAirports import
OURAIRPORTS_TIMEOUT=30s
OURAIRPORTS_COUNTRY_CODES=AZ,GE,AM,TR

# Database migrations
MIGRATIONS_DIR=../../database/migrations
MIGRATION_TIMEOUT=2m

# Historical Intelligence production materialization
# Optional. Defaults to 5m when omitted.
HISTORICAL_MATERIALIZATION_TIMEOUT=5m

# OPENSKY-PRODUCTION-PROVIDER-V1
# Select airplanes.live, opensky, or auto. Default: airplanes.live
# auto tries airplanes.live first and calls OpenSky only after a recoverable failure.
TRAFFIC_PROVIDER=airplanes.live

# Optional OpenSky production provider
OPENSKY_BASE_URL=https://opensky-network.org/api
OPENSKY_TOKEN_URL=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
OPENSKY_TIMEOUT=15s
OPENSKY_POLLING_INTERVAL=10s

# TRAFFIC-PROVIDER-AUTOMATIC-FALLBACK-V1
# Optional automatic provider chain:
# TRAFFIC_PROVIDER=auto

# STAGE-14-5-MUTATION-ENDPOINT-PROTECTION
